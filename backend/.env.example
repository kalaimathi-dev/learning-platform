# Server
PORT=5000
NODE_ENV=production

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/learning-platform?retryWrites=true&w=majority

# JWT secret (use a long random string)
JWT_SECRET=replace_with_a_very_long_random_secret_at_least_32_chars

# Allowed frontend origins for CORS (comma-separated if multiple)
FRONTEND_URL=https://your-frontend.vercel.app
